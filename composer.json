    "version": "1.0.1",
    "license": "proprietary",
    "keywords": [
        "magento2",
        "magento2-module",
        "checkout",
        "success",
        "order-confirmation",
        "thank-you-page",
        "order-summary",
        "tracking",
        "conversion"
    ],
    "homepage": "https://kishansavaliya.com",
    "support": {
        "email": "kishansavaliyakb@gmail.com",
        "source": "https://kishansavaliya.com"
    },
    "authors": [
        {
            "name": "Kishan Savaliya",
            "email": "kishansavaliyakb@gmail.com",
            "homepage": "https://kishansavaliya.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "mage2kishan/module-core": "^1.0",
        "magento/framework": "^103.0",
        "magento/module-checkout": "^100.4",
        "magento/module-sales": "^103.0",
        "magento/module-catalog": "^104.0",
