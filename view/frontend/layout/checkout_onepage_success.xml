<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Panth_CheckoutSuccess::css/checkout-success.css"/>
    </head>
    <body>
        <attribute name="class" value="panth-checkout-success"/>

        <!-- Hide default Magento page title -->
        <referenceBlock name="page.main.title" remove="true"/>

        <!-- Hide default Magento success content (we have our own) -->
        <referenceBlock name="checkout.success" remove="true"/>
        <referenceBlock name="checkout.registration" remove="true"/>

        <!-- Our custom success page -->
        <referenceContainer name="content">
            <block class="Panth\CheckoutSuccess\Block\Success"
                   name="panth.checkout.success"
                   template="Panth_CheckoutSuccess::success.phtml"
                   cacheable="false"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
